  "version": 2,
  "name": "qr-generator",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/ramesh", "destination": "/index.html" },
    { "source": "/ramesh/", "destination": "/index.html" }
  ]
}
